generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================================================
// ENUMS
// ==================================================

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  ADVOCATE
  JUNIOR_LAWYER
  CLERK
  ACCOUNTANT
  CLIENT
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum SubscriptionPlanType {
  MONTHLY
  YEARLY
  LIFETIME
}

enum CaseStatus {
  PRE_LITIGATION
  FILED
  ONGOING
  STAYED
  DISPOSED
  APPEALED
  CLOSED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum HearingStatus {
  SCHEDULED
  ADJOURNED
  HEARD
  CANCELLED
}

enum DocumentType {
  LEGAL_BRIEF
  EVIDENCE
  COURT_ORDER
  CONTRACT
  ID_PROOF
  INVOICE
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
  FAILED
  REFUNDED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum NotificationType {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum ReminderChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ==================================================
// CORE MODELS
// ==================================================

model Tenant {
  id       String       @id @default(uuid())
  name     String
  slug     String       @unique
  email    String       @unique
  phone    String?
  address  String?
  city     String?
  province String?
  logoUrl  String?
  status   TenantStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users         User[]
  clients       Client[]
  cases         Case[]
  hearings      Hearing[]
  documents     Document[]
  tasks         Task[]
  invoices      Invoice[]
  payments      Payment[]
  subscriptions    Subscription[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  settings         TenantSetting?
  hearingReminders HearingReminder[]

  @@index([slug])
  @@index([email])
  @@index([status])
  @@map("tenants")
}

model User {
  id          String    @id @default(uuid())
  tenantId    String? // Nullable for SUPER_ADMIN
  authUserId  String?   @unique // Link to Supabase Auth if used
  name        String
  email       String    @unique
  phone       String?
  password    String? // If using local auth instead of Supabase
  role        UserRole  @default(ADVOCATE)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  // Granular RBAC fallback from existing architecture
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant        Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientProfile Client? @relation("UserClient")

  // Created/Assigned relations
  assignedCases    Case[]     @relation("CaseAssignedTo")
  createdHearings  Hearing[]  @relation("HearingCreatedBy")
  uploadedDocs     Document[] @relation("DocumentUploadedBy")
  assignedTasks    Task[]     @relation("TaskAssignedTo")
  createdTasks     Task[]     @relation("TaskCreatedBy")
  auditLogs        AuditLog[]
  messagesSent     Message[]  @relation("MessageSender")
  messagesReceived Message[]  @relation("MessageReceiver")

  @@index([tenantId])
  @@index([role])
  @@index([email])
  @@index([authUserId])
  @@map("users")
}

model Client {
  id         String  @id @default(uuid())
  tenantId   String
  userId     String? @unique // Optional link to User for Client Portal
  name       String
  fatherName String?
  cnic       String?
  phone      String
  whatsapp   String?
  email      String?
  address    String?
  city       String?
  notes      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation("UserClient", fields: [userId], references: [id], onDelete: SetNull)

  cases            Case[]
  documents        Document[]
  invoices         Invoice[]
  payments         Payment[]
  Message          Message[]
  hearingReminders HearingReminder[]

  @@index([tenantId])
  @@index([phone])
  @@index([cnic])
  @@index([email])
  @@map("clients")
}

model Case {
  id              String       @id @default(uuid())
  tenantId        String
  clientId        String
  assignedToId    String?
  caseTitle       String
  caseNumber      String
  firNumber       String?
  courtName       String
  judgeName       String?
  caseType        String
  status          CaseStatus   @default(PRE_LITIGATION)
  priority        CasePriority @default(MEDIUM)
  filingDate      DateTime?
  nextHearingDate DateTime?
  oppositeParty   String
  oppositeCounsel String?
  policeStation   String?
  legalSections   String?
  description     String?
  internalNotes   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?
  deletedAt DateTime?

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client     Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  assignedTo User?  @relation("CaseAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  hearings         Hearing[]
  documents        Document[]
  tasks            Task[]
  invoices         Invoice[]
  payments         Payment[]
  messages         Message[]
  hearingReminders HearingReminder[]

  @@unique([tenantId, caseNumber])
  @@index([tenantId])
  @@index([clientId])
  @@index([status])
  @@index([nextHearingDate])
  @@index([caseNumber])
  @@map("cases")
}

model Hearing {
  id              String        @id @default(uuid())
  tenantId        String
  caseId          String
  hearingDate     DateTime
  hearingTime     String?
  courtName       String
  purpose         String
  status          HearingStatus @default(SCHEDULED)
  remarks         String?
  nextHearingDate DateTime?
  orderSummary    String?
  createdById     String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case             Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy        User              @relation("HearingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  hearingReminders HearingReminder[]

  @@index([tenantId])
  @@index([caseId])
  @@index([hearingDate])
  @@index([status])
  @@map("hearings")
}

model Document {
  id           String       @id @default(uuid())
  tenantId     String
  caseId       String?
  clientId     String?
  uploadedById String
  title        String
  type         DocumentType @default(OTHER)
  fileUrl      String
  fileKey      String?
  mimeType     String?
  size         Int?
  isPrivate    Boolean      @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case       Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client     Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  uploadedBy User    @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([caseId])
  @@index([clientId])
  @@index([type])
  @@map("documents")
}

model Task {
  id           String       @id @default(uuid())
  tenantId     String
  caseId       String?
  assignedToId String?
  createdById  String
  title        String
  description  String?
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  dueDate      DateTime?
  completedAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case       Case?  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignedTo User?  @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User   @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([assignedToId])
  @@index([caseId])
  @@index([dueDate])
  @@index([status])
  @@map("tasks")
}

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String
  clientId      String
  caseId        String?
  invoiceNumber String
  amount        Float
  discount      Float         @default(0)
  tax           Float         @default(0)
  totalAmount   Float
  paidAmount    Float         @default(0)
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  case   Case?  @relation(fields: [caseId], references: [id], onDelete: SetNull)

  payments Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([clientId])
  @@index([caseId])
  @@index([status])
  @@map("invoices")
}

model Payment {
  id        String        @id @default(uuid())
  tenantId  String
  clientId  String
  caseId    String?
  invoiceId String?
  amount    Float
  method    String
  reference String?
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client  Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  case    Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([clientId])
  @@index([caseId])
  @@index([status])
  @@map("payments")
}

model Plan {
  id                         String               @id @default(uuid())
  name                       String
  type                       SubscriptionPlanType @default(MONTHLY)
  priceMonthly               Float
  priceYearly                Float
  maxUsers                   Int
  maxCases                   Int
  maxClients                 Int
  maxStorageGB               Int
  allowClientPortal          Boolean              @default(false)
  allowWhatsAppNotifications Boolean              @default(false)
  allowAdvancedReports       Boolean              @default(false)
  allowCustomBranding        Boolean              @default(false)
  allowAI                    Boolean              @default(false)
  isActive                   Boolean              @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String
  planId               String
  status               SubscriptionStatus @default(TRIAL)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([status])
  @@map("subscriptions")
}

model AuditLog {
  id        String  @id @default(uuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String
  details   Json?
  ipAddress String?

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model Notification {
  id       String           @id @default(uuid())
  tenantId String
  type     NotificationType @default(IN_APP)
  title    String
  message  String
  isRead   Boolean          @default(false)
  readAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isRead])
  @@map("notifications")
}

model Message {
  id         String  @id @default(uuid())
  caseId     String?
  clientId   String?
  senderId   String
  receiverId String
  content    String
  isRead     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case     Case?   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sender   User    @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  receiver User    @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Restrict)

  @@index([senderId])
  @@index([receiverId])
  @@index([caseId])
  @@map("messages")
}

model HearingReminder {
  id            String          @id @default(uuid())
  tenantId      String
  clientId      String?
  caseId        String?
  hearingId     String?
  scheduledFor  DateTime
  channel       ReminderChannel @default(IN_APP)
  status        ReminderStatus  @default(PENDING)
  message       String
  sentAt        DateTime?
  failedAt      DateTime?
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  case    Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  hearing Hearing? @relation(fields: [hearingId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([scheduledFor])
  @@index([hearingId])
  @@map("hearing_reminders")
}

model Court {
  id   String @id @default(uuid())
  name String
  city String
  type String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("courts")
}

model CaseType {
  id   String @id @default(uuid())
  name String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("case_types")
}

model TenantSetting {
  id                  String  @id @default(uuid())
  tenantId            String  @unique
  themeColor          String?
  timezone            String  @default("Asia/Karachi")
  currency            String  @default("PKR")
  invoicePrefix       String  @default("INV-")
  whatsappEnabled     Boolean @default(false)
  whatsappPhoneNumber String?
  smsEnabled          Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}
