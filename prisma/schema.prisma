datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPERADMIN
  ADVOCATE
  MUNSHI
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum PaymentStatus {
  PAID
  PENDING
}

model User {
  id             String           @id @default(uuid())
  name           String
  email          String           @unique
  password       String
  role           Role             @default(ADVOCATE)
  profilePicture String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  
  // Relations
  portal         AdvocatePortal?  @relation("AdvocateToPortal")
  
  // As Advocate: has Munshis, Clients, and Payments
  munshis        MunshiAccount[]  @relation("AdvocateToMunshis")
  clients        Client[]         @relation("AdvocateToClients")
  payments       Payment[]        @relation("AdvocateToPayments")

  // As Munshi: has one MunshiAccount
  munshiProfile  MunshiAccount?   @relation("MunshiToAccount")

  @@map("users")
}

model AdvocatePortal {
  id                 String             @id @default(uuid())
  advocateId         String             @unique
  portalName         String
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  monthlyFee         Float              @default(0.0)
  nextPaymentDue     DateTime
  createdAt          DateTime           @default(now())

  // Relations
  advocate           User               @relation("AdvocateToPortal", fields: [advocateId], references: [id], onDelete: Cascade)

  @@map("advocate_portals")
}

model MunshiAccount {
  id         String   @id @default(uuid())
  munshiId   String   @unique
  advocateId String
  permissions Json     // Stores permissions as a JSON array or object
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  // Relations
  munshi     User     @relation("MunshiToAccount", fields: [munshiId], references: [id], onDelete: Cascade)
  advocate   User     @relation("AdvocateToMunshis", fields: [advocateId], references: [id], onDelete: Cascade)

  @@map("munshi_accounts")
}

model Client {
  id         String   @id @default(uuid())
  name       String
  cnic       String?
  phone      String
  email      String?
  address    String?
  advocateId String
  addedBy    String   // User ID who added the client (Advocate or Munshi)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  advocate   User     @relation("AdvocateToClients", fields: [advocateId], references: [id], onDelete: Cascade)

  @@map("clients")
}

model Payment {
  id         String        @id @default(uuid())
  advocateId String
  amount     Float
  status     PaymentStatus @default(PENDING)
  dueDate    DateTime
  paidAt     DateTime?
  createdAt  DateTime      @default(now())

  // Relations
  advocate   User          @relation("AdvocateToPayments", fields: [advocateId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model SiteSettings {
  id        String   @id @default(uuid())
  logoUrl   String
  siteName  String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}
