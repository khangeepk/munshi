# ─── Database (SQLite via better-sqlite3 / Prisma v7) ─────────────────────────
DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"

# ─── Session / Auth Secret ─────────────────────────────────────────────────────
AUTH_SECRET="lawyersys-change-this-secret-in-production-2026"

# ─── WhatsApp Integration ──────────────────────────────────────────────────────
# Set to "true" to enable the whatsapp-web.js headless client.
# When disabled (or on serverless), the system falls back to wa.me deep links.
WHATSAPP_ENABLED=true

# ─── Hearing Reminder Scheduler ───────────────────────────────────────────────
# Cron schedule for daily reminders (default: 8 AM Pakistan time)
REMINDER_CRON="0 8 * * *"
# Days before hearing to send reminders (comma-separated)
REMINDER_DAYS_BEFORE="1,3,7"

# ─── Supabase (optional — only needed for real-time DB sync features) ──────────
# Leave commented out if you are not using Supabase. App works fully offline.
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"